# Claude Agent SDK helper — environment.
# Copy to `.env` (auto-loaded if you run via `node --env-file=.env server.mjs`)
# or just export these in your shell before `npm run agent`.

# Max-subscription OAuth token. Generate with:  claude setup-token
# (Alternatively, run `claude login` once and the SDK uses ~/.claude credentials;
#  in that case this can stay unset.)
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: port the helper listens on (default 8787). Must match the
# "Helper URL" in the app's AI settings.
AGENT_SIDECAR_PORT=8787

# Optional: default model when the app doesn't pin one (default claude-opus-4-8).
AGENT_SDK_MODEL=claude-opus-4-8

# NOTE: ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN are deleted by the helper at
# startup (Max subscription only). Setting them here has no effect.
